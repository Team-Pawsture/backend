# ============================================
# .env.example
# - 실제 값은 .env 파일에 작성 (절대 깃에 올리지 말 것)
# - 새 개발자는 이 파일을 .env로 복사해서 placeholder를 실제 값으로 교체
# ============================================


# --------------------------------------------
# 서버 공개 베이스 URL
# - 사용처: app/utils/url_helper.py (이미지 등 정적 리소스 절대 URL 조립)
# - 로컬 개발: http://localhost:8000
# - 배포 시 https://www.pasture.com 같은 실제 도메인으로 변경
# - 끝에 슬래시(/) 붙이지 말 것
# --------------------------------------------
BASE_URL=http://localhost:8000


# --------------------------------------------
# 데이터베이스 (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgresql://your_db_user_here:your_db_password_here@localhost:5432/your_db_name_here


# --------------------------------------------
# JWT (인증 토큰)
# --------------------------------------------
# JWT_SECRET_KEY: 무작위 긴 문자열 권장 (예: openssl rand -hex 32)
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60


# --------------------------------------------
# AI 분석 서버 (슬개골 탈구 영상 분석)
# - 사용처: app/utils/ai_client.py
# - 명세서: AI 서버 v3 (POST /api/v1/patella/analyze, GET /api/v1/patella/jobs/{jobId})
# - AI /analyze는 동기 호출, 평균 34초/최대 72초 → 백엔드는 BackgroundTasks로 호출
# - 미설정 + AI_MOCK_MODE=false 시 백그라운드에서 failed로 기록됨
# - 끝에 슬래시(/) 붙이지 말 것
# --------------------------------------------
AI_SERVER_URL=

# AI 서버 없이 가짜 응답으로 프론트 연동 테스트할 때 사용.
# true 설정 시 AI_SERVER_URL 무시하고 즉시 가짜 결과 반환.
AI_MOCK_MODE=false

# AI_MOCK_MODE=true 일 때 응답 시나리오 선택.
# 옵션: completed (기본, 의심 신호) | rejected (품질 거절) | failed (AI 처리 실패)
AI_MOCK_SCENARIO=completed

# 병원 추천 점수 계산용 내부 매핑 토글.
# true면 AI decision → predicted_stage 매핑값을 ai_result._internal_predicted_stage 에 저장.
# 응답에는 절대 노출하지 않음 (의료 정보 안전 정책).
# 추후 AI팀과 매핑 규칙 확정되면 응답 prediction.predicted_stage로 이전 예정.
AI_INTERNAL_STAGE_MAPPING=false


# --------------------------------------------
# 네이버 클라우드 플랫폼 (Directions 5 API)
# - 사용처: app/utils/naver_api.py (병원 거리/시간 계산)
# - 콘솔: https://www.ncloud.com → Maps → Directions 5 활성화 필요
# --------------------------------------------
NAVER_CLOUD_CLIENT_ID=your_naver_cloud_client_id_here
NAVER_CLOUD_CLIENT_SECRET=your_naver_cloud_client_secret_here


# --------------------------------------------
# 카카오 디벨로퍼스 (로컬 검색 API)
# - 사용처: app/utils/kakao_api.py (근처 동물병원 검색)
# - 콘솔: https://developers.kakao.com → 내 애플리케이션 → 카카오맵 활성화 필요
# --------------------------------------------
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here


# --------------------------------------------
# Web Push (VAPID)
# - 사용처: app/utils/push_sender.py (브라우저 푸시 알림 발송)
# - VAPID 키 발급: venv 활성화 후 `vapid --gen` 실행
#   → private_key.pem, public_key.pem 두 파일이 현재 디렉터리에 생성됨
# - public key는 `vapid --applicationServerKey` 명령으로 base64 형태 추출 가능
#   (프론트엔드가 applicationServerKey 로 사용하는 값)
# - PRIVATE_KEY는 .pem 파일 경로를 그대로 넣음 (pywebpush가 파일 경로 지원)
#   → 서버를 프로젝트 루트에서 실행할 것 (상대 경로 기준)
# - ⚠️ private_key.pem은 .gitignore에 반드시 추가 (절대 깃에 올리지 말 것)
# - CLAIM_EMAIL: 푸시 서비스(FCM/Mozilla 등)에 연락처 알리는 용도, mailto: 형식 필수
# --------------------------------------------
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=./private_key.pem
VAPID_CLAIM_EMAIL=mailto:your_email@example.com
